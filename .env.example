# ─── 运行参数 ─────────────────────────────────────────────────
MAILBOX="126"
AI="deepseek"
# MODE="idle"            # idle（IMAP IDLE，默认）/ poll（定时轮询）
# POLL_INTERVAL="60"     # 轮询间隔（秒），仅 MODE=poll 时生效

# ─── 日志与稳定性 ──────────────────────────────────────────────
# LOG_MAX_BYTES="10485760"  # 单个日志文件最大字节数（默认 10MB）
# LOG_BACKUP_COUNT="5"      # 日志文件保留份数（默认 5）
# MAX_PROCESSED_IDS="5000"  # 已处理邮件 ID 最大保留数量（默认 5000）
# TASK_MAX_RETRIES="3"      # 任务失败最大重试次数（默认 3）

# ─── 自动任务识别 ─────────────────────────────────────────────
# AUTO_DETECT_TASKS="true"  # 是否启用自动任务识别（true/false），默认 true
                           # 设为 false 可禁用"任务："前缀的自动解析功能

# ─── Web UI ───────────────────────────────────────────────────
# WEBUI_HOST="0.0.0.0"   # Web UI 监听地址（默认 0.0.0.0）
# WEBUI_PORT="8000"       # Web UI 端口（默认 8000）
# WEBUI_PASSWORD=""       # Web UI 访问密码（留空则不需要登录）
# WEBUI_SECRET=""         # Session 签名密钥（留空则每次启动自动生成）
# WEBUI_LANG="zh"         # Web UI 界面语言：zh（中文）/ ja（日本語）/ ko（한국어）/ en（English）

# ─── 邮箱配置（填写你的真实信息）────────────────────────────
# 126 / 163 / QQ：需要邮箱授权码（非登录密码），在邮箱设置 → POP3/IMAP → 开启服务时获取
MAIL_126_ADDRESS="your@126.com"
MAIL_126_PASSWORD="your-auth-code"
MAIL_126_ALLOWED="your@126.com"

# MAIL_163_ADDRESS="your@163.com"
# MAIL_163_PASSWORD="your-auth-code"
# MAIL_163_ALLOWED="your@163.com"

# MAIL_QQ_ADDRESS="your@qq.com"
# MAIL_QQ_PASSWORD="your-auth-code"
# MAIL_QQ_ALLOWED="your@qq.com"

# ─── Gmail 应用专用密码（简单，无需 OAuth）──────────────────
# 1. Google 账号 → 安全 → 两步验证 → 应用专用密码 → 生成 16 位密码
# 2. Gmail 设置 → 转发和 POP/IMAP → 启用 IMAP
# MAIL_GMAIL_ADDRESS="your@gmail.com"
# MAIL_GMAIL_PASSWORD="xxxx xxxx xxxx xxxx"
# MAIL_GMAIL_ALLOWED="your@gmail.com"
# MAIL_GMAIL_AUTH="password"   # 使用应用密码时必须加此行；不加则默认使用 OAuth

# ─── Gmail OAuth（推荐）────────────────────────────────────
# 1. Google Cloud Console 创建项目，启用 Gmail API
# 2. 下载 OAuth 凭据文件，保存为 credentials_gmail.json 放到本目录
# 3. 首次授权（仅一次）: python3 email_daemon.py --mailbox gmail --auth
# MAIL_GMAIL_ADDRESS="your@gmail.com"
# MAIL_GMAIL_ALLOWED="your@gmail.com"

# ─── Outlook OAuth（设备码）────────────────────────────────
# 1. Azure Portal 注册应用，获取 Client ID（支持个人 Microsoft 账户）
# 2. 首次授权（仅一次）: python3 email_daemon.py --mailbox outlook --auth
# MAIL_OUTLOOK_ADDRESS="your@outlook.com"
# OUTLOOK_CLIENT_ID="your-azure-app-client-id"
# MAIL_OUTLOOK_ALLOWED="your@outlook.com"

# ─── 其他邮箱（自定义 IMAP/SMTP）──────────────────────────
# 适用于任意支持 IMAP/SMTP + 授权码 / 应用密码 的邮箱
# MAIL_CUSTOM_ADDRESS="your@example.com"
# MAIL_CUSTOM_PASSWORD="your-password"
# MAIL_CUSTOM_ALLOWED="your@example.com"
# MAIL_CUSTOM_IMAP_SERVER="imap.example.com"
# MAIL_CUSTOM_IMAP_PORT="993"
# MAIL_CUSTOM_SMTP_SERVER="smtp.example.com"
# MAIL_CUSTOM_SMTP_PORT="465"
# MAIL_CUSTOM_SMTP_SSL="true"

# ─── 邮件整理专用邮箱（用于自动归类/移动/标记）────────────
# 专门用于处理邮件整理指令的邮箱，与守护进程邮箱独立
# 支持多个管理邮箱：sort, sort2, sort3, ...
# 管理邮箱只执行移动/删除/标记操作，不回复邮件
# MAIL_SORT_ADDRESS="your-sort@example.com"
# MAIL_SORT_PASSWORD="your-password"
# MAIL_SORT_ALLOWED="your-sort@example.com"
# MAIL_SORT_IMAP_SERVER="imap.example.com"
# MAIL_SORT_IMAP_PORT="993"
# MAIL_SORT_SMTP_SERVER="smtp.example.com"
# MAIL_SORT_SMTP_PORT="465"
# MAIL_SORT_SMTP_SSL="true"

# 第二个管理邮箱（如需要更多，复制此段并修改为 sort3, sort4...）
# MAIL_SORT2_ADDRESS="your-sort2@example.com"
# MAIL_SORT2_PASSWORD="your-password"
# MAIL_SORT2_ALLOWED="your-sort2@example.com"
# MAIL_SORT2_IMAP_SERVER="imap.example.com"
# MAIL_SORT2_IMAP_PORT="993"
# MAIL_SORT2_SMTP_SERVER="smtp.example.com"
# MAIL_SORT2_SMTP_PORT="465"
# MAIL_SORT2_SMTP_SSL="true"

# 第三个管理邮箱
# MAIL_SORT3_ADDRESS="your-sort3@example.com"
# MAIL_SORT3_PASSWORD="your-password"
# MAIL_SORT3_ALLOWED="your-sort3@example.com"
# MAIL_SORT3_IMAP_SERVER="imap.example.com"
# MAIL_SORT3_IMAP_PORT="993"
# MAIL_SORT3_SMTP_SERVER="smtp.example.com"
# MAIL_SORT3_SMTP_PORT="465"
# MAIL_SORT3_SMTP_SSL="true"

# ─── AI API Key（按需填写一个）──────────────────────────────
# 国际模型
# DEEPSEEK_API_KEY="sk-xxx"
# ANTHROPIC_API_KEY="sk-ant-xxx"
# OPENAI_API_KEY="sk-xxx"
# GEMINI_API_KEY="AIzaxxx"
# GROQ_API_KEY="gsk_xxx"              # Groq 高速推理
# PERPLEXITY_API_KEY="plx_xxx"        # Perplexity 搜索增强
# COHERE_API_KEY="xxx"                # Cohere 企业级

# 中国模型
# QWEN_API_KEY="sk-xxx"               # 通义千问（阿里云）
# MOONSHOT_API_KEY="sk-xxx"           # 月之暗面 Kimi
# GLM_API_KEY="xxx"                   # 智谱 AI（清华系）
# SPARK_API_KEY="xxx:xxx"             # 讯飞星火（APIKey:APISecret）
# ERNIE_API_KEY="xxx:xxx"             # 百度文心一言（APIKey:SecretKey）
# YI_API_KEY="xxx"                    # 零一万物

# 本地 LLM（无需 API Key，需本地服务运行中）
# OLLAMA_BASE_URL="http://localhost:11434"  # Ollama 服务地址（默认）
# OLLAMA_MODEL=""                           # 留空则自动选取第一个已安装模型
# VLLM_BASE_URL="http://localhost:8000"     # vLLM 服务地址（默认）
# VLLM_MODEL=""                             # vLLM 加载的模型名称
# VLLM_API_KEY="EMPTY"                      # vLLM 默认不鉴权，保持 EMPTY 即可

# CLI 方式（需预先安装对应 CLI 工具）
# GITHUB_COPILOT_TOKEN="ghu_xxx"   # ghp_ / ghu_ / ghs_ 均可

# ─── Web Search（可选，为 AI 回复注入实时搜索结果）──────────
# WEB_SEARCH="false"               # 默认禁用搜索引擎，避免处理延迟
# WEB_SEARCH_ENGINE="duckduckgo"   # google 爬虫已禁用       # google（默认，无需 API Key）/ duckduckgo / brave / wikipedia / bing
# SEARCH_RESULTS_COUNT="5"
# WIKIPEDIA_LANG="zh"
# GOOGLE_API_KEY="your-api-key"    # 使用 google 引擎时需要
# GOOGLE_CSE_ID="your-cse-id"
# BING_API_KEY="your-bing-api-key"   # 使用 bing 引擎时需要
# BRAVE_API_KEY="your-brave-api-key" # 使用 brave 引擎时需要（免费 2000次/月）

# ─── 定时任务与外部数据（可选）─────────────────────────────
# WEATHER_API_KEY="your-weatherapi-key"    # WeatherAPI
# NEWS_API_KEY="your-newsapi-key"          # NewsAPI
# TASK_DEFAULT_AI="deepseek"               # 定时任务使用的 AI（不填则用启动参数 --ai）
# WEATHER_DEFAULT_LOCATION="Tokyo"
# NEWS_DEFAULT_QUERY="technology OR AI"
# NEWS_DEFAULT_LANGUAGE="zh"
# NEWS_DEFAULT_PAGE_SIZE="8"

# ─── MCP（Model Context Protocol）插件（可选）────────────
# 通过 MCP 扩展 AI 能力，直接用 subprocess 调用本地 MCP 服务器，无需额外依赖库
# 留空则 MCP 功能关闭，不影响其他功能
# MCP_SERVERS=filesystem,github           # 启用的服务器（逗号分隔），不填则全部禁用
# MCP_SERVER_FILESYSTEM=npx -y @modelcontextprotocol/server-filesystem /home/user/reports
# MCP_SERVER_GITHUB=npx -y @modelcontextprotocol/server-github
# MCP_SERVER_SQLITE=npx -y @modelcontextprotocol/server-sqlite /path/to/db.sqlite
# 使用示例（邮件指令）：
#   task_type: mcp_call
#   task_payload: {"server": "filesystem", "tool": "list_directory", "args": {"path": "/home/user/reports"}}
#   查询可用工具：{"server": "filesystem", "tool": "__list__"}

# ─── 一键退订（RFC 8058 List-Unsubscribe，可选）───────────
# 为定时/循环邮件自动添加 List-Unsubscribe 标头，支持 Gmail/Outlook/Apple Mail 的原生一键退订按钮
# UNSUBSCRIBE_BASE_URL="https://mailmind.example.com"  # Web UI 公网 HTTPS 地址（留空则不添加退订标头）
# UNSUBSCRIBE_SECRET=""           # HMAC 签名密钥（留空则自动生成并保存到 .unsubscribe_secret）

# ─── Shell 执行技能（可选，安全沙箱）──────────────────────
# SHELL_EXEC_ALLOW=""         # 命令白名单（逗号分隔），如：ls,cat,git,python。留空=全部拒绝；*=全部允许（不推荐）
# SHELL_EXEC_TIMEOUT="30"    # 每条命令超时秒数（默认 30）

# ─── Telegram Bot（可选）──────────────────────────────────
# TELEGRAM_BOT_TOKEN=""       # 从 @BotFather 获取
# TELEGRAM_ALLOWED_CHATS=""   # 允许的 chat ID（逗号分隔），留空则拒绝所有
# TELEGRAM_POLL_TIMEOUT="30"  # 长轮询超时（秒，默认 30）
# CHANNEL_POLL_INTERVAL="5"  # 消息渠道轮询间隔（秒，默认 5）

# ─── Discord Bot（可选）───────────────────────────────────
# DISCORD_BOT_TOKEN=""        # Discord 开发者后台 Bot Token
# DISCORD_CHANNEL_IDS=""      # 监听的频道 ID（逗号分隔）
# DISCORD_PUBLIC_KEY=""       # Webhook 验签公钥（可选）

# ─── GitHub（可选，供 github/ticket 技能使用）─────────────
# GITHUB_TOKEN=""             # GitHub Personal Access Token（ghp_xxx）

# ─── Jira（可选，供 ticket 技能使用）─────────────────────
# JIRA_BASE_URL=""            # 如：https://yourcompany.atlassian.net
# JIRA_EMAIL=""               # Jira 账户邮箱
# JIRA_API_TOKEN=""           # Jira API Token

# ─── Linear（可选，供 ticket 技能使用）────────────────────
# LINEAR_API_KEY=""           # Linear API Key

# ─── Google Calendar（可选，供 calendar 技能使用）─────────
# GOOGLE_CALENDAR_ID="primary"  # 日历 ID（默认 primary）
# CALENDAR_BACKEND="auto"       # auto / google / ics

# ─── Gmail Push Notifications（可选，低延迟接收模式）──────
# 需要：google-api-python-client 已安装 + Web UI 运行中 + GCP Pub/Sub 已配置
# 参考 core/gmail_pubsub.py 头部注释了解完整配置步骤
# GMAIL_PUBSUB_TOPIC=""         # 如：projects/my-project/topics/mailmind-gmail
# GMAIL_PUSH_ENDPOINT=""        # 公网 HTTPS Webhook URL（留空则使用 UNSUBSCRIBE_BASE_URL/webhook/gmail）
# MODE="gmail_push"             # 启用 Gmail Push 模式（或启动时加 --gmail-push）

# ─── 高级选项（可选）──────────────────────────────────────
# ATTACHMENT_MAX_SIZE_MB="10"     # 附件大小上限（MB），超出则跳过，默认 10MB
# AI_CONCURRENCY="3"              # 同时调用 AI 的最大并发数，默认 3
# CONTEXT_MAX_DEPTH="5"           # 获取会话历史的最大层数，默认 5
# MAX_EMAIL_CHARS="4000"          # 邮件正文最大字符数（超出截断），默认 4000
# PROMPT_LANG="zh"                # 提示语言：zh（中文）/ ja（日本語）/ en（English）（可被邮件语言自动检测覆盖）
# PROMPT_TEMPLATE_FILE=""         # 自定义提示模板文件路径（优先于 PROMPT_LANG）

# ─── Workspace（可选，限制 AI 操作范围）────────────────────
# WORKSPACE_DIR="./workspace"     # AI 允许操作的文件目录（留空则不限制）
#                                 # 归档输出（reports/ 等）将限制在此目录内
#                                 # 防止路径穿越攻击，增强安全性
