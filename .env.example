# ─── 运行参数 ─────────────────────────────────────────────────
# ─── Runtime (English) ───────────────────────────────────────
# ─── 実行パラメータ（日本語）─────────────────────────────────
# ─── 실행 파라미터（한국어）──────────────────────────────────
MAILBOX="126"          # Mailbox: 126 / 163 / qq / gmail / outlook
AI="codex"             # AI: claude / codex / gemini / anthropic / openai / gemini-api / qwen-api / deepseek / copilot
MODE="idle"            # Mode: idle (IMAP IDLE) / poll (interval polling)
POLL_INTERVAL="60"     # Poll interval in seconds (only MODE=poll)

# ─── 邮箱环境变量（填写你的真实信息）──────────────────────────
# ─── Mailbox credentials (English) ───────────────────────────
# ─── メールボックス認証情報（日本語）────────────────────────
# ─── 메일함 자격 증명（한국어）────────────────────────────
MAIL_126_ADDRESS="your@126.com"
MAIL_126_PASSWORD="your-auth-code"
MAIL_126_ALLOWED="your@126.com"

# MAIL_163_ADDRESS="your@163.com"
# MAIL_163_PASSWORD="your-auth-code"
# MAIL_163_ALLOWED="your@163.com"

# MAIL_QQ_ADDRESS="your@qq.com"
# MAIL_QQ_PASSWORD="your-auth-code"
# MAIL_QQ_ALLOWED="your@qq.com"

# Gmail OAuth（推荐 / Recommended / 推奨 / 권장）：
#   1. 在 Google Cloud Console 创建项目并启用 Gmail API
#   2. 创建 OAuth 凭据（桌面应用），下载为 credentials_gmail.json 放到本目录
#   3. 首次运行: python3 email_daemon.py --mailbox gmail --auth  （按提示授权）
# MAIL_GMAIL_ADDRESS="your@gmail.com"
# MAIL_GMAIL_ALLOWED="your@gmail.com"
# Gmail 应用专用密码（简单方式 / App Password / アプリパスワード / 앱 비밀번호）：
# MAIL_GMAIL_ADDRESS="your@gmail.com"
# MAIL_GMAIL_PASSWORD="xxxx xxxx xxxx xxxx"
# MAIL_GMAIL_ALLOWED="your@gmail.com"

# Outlook OAuth（设备码 / Device code / デバイスコード / 장치 코드）：
#   1. 在 Azure Portal 注册应用，获取 Client ID
#   2. 首次运行: python3 email_daemon.py --mailbox outlook --auth  （设备码授权）
# MAIL_OUTLOOK_ADDRESS="your@outlook.com"
# OUTLOOK_CLIENT_ID="your-azure-app-client-id"
# MAIL_OUTLOOK_ALLOWED="your@outlook.com"

# ─── AI API Key（按需填写）──────────────────────────────────────
# ─── AI API Keys (English) ───────────────────────────────────
# ─── AI API キー（日本語）───────────────────────────────────
# ─── AI API 키（한국어）────────────────────────────────────
# ANTHROPIC_API_KEY="sk-ant-xxx"
# OPENAI_API_KEY="sk-xxx"
# GEMINI_API_KEY="AIzaxxx"
# QWEN_API_KEY="sk-xxx"
# DEEPSEEK_API_KEY="sk-xxx"
# GITHUB_COPILOT_TOKEN="ghu_xxx"   # GitHub Copilot token (ghp_ / ghu_ / ghs_)

# ─── Web Search 配置（可选）────────────────────────────────────
# ─── Web Search (English) ────────────────────────────────────
# ─── Web検索（日本語）────────────────────────────────────────
# ─── 웹 검색（한국어）────────────────────────────────────────
# WEB_SEARCH="true"                # Enable web search (true / false)
# WEB_SEARCH_ENGINE="duckduckgo"   # Engine: duckduckgo / wikipedia / google / bing
# SEARCH_RESULTS_COUNT="5"         # Number of results
# WIKIPEDIA_LANG="zh"              # Wikipedia language

# Google Custom Search API（如使用 google 引擎 / if using google / google利用時 / 구글 사용 시）：
# GOOGLE_API_KEY="your-api-key"
# GOOGLE_CSE_ID="your-cse-id"

# Bing Search API（如使用 bing 引擎 / if using bing / bing利用時 / bing 사용 시）：
# BING_API_KEY="your-bing-api-key"

# ─── 外部数据与定时任务（默认方案）────────────────────────────
# ─── External Data & Scheduled Tasks (Default) ───────────────
# ─── 外部データと定期タスク（デフォルト）─────────────────────
# ─── 외부 데이터 및 정기 작업(기본) ────────────────────────
# WEATHER_API_KEY="your-weatherapi-key"    # WeatherAPI key
# NEWS_API_KEY="your-newsapi-key"          # NewsAPI key
# TASK_DEFAULT_AI="openai"                 # Default AI for scheduled tasks
# WEATHER_DEFAULT_LOCATION="Tokyo"         # Default weather location
# NEWS_DEFAULT_QUERY="technology OR AI"    # Default news query
# NEWS_DEFAULT_LANGUAGE="zh"               # Default news language
# NEWS_DEFAULT_COUNTRY=""                  # Default country for top headlines
# NEWS_DEFAULT_PAGE_SIZE="8"               # Default page size
