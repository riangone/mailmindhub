# ─── 运行参数 ─────────────────────────────────────────────────
MAILBOX="126"          # 邮箱: 126 / 163 / qq / gmail / outlook
AI="codex"             # AI:   claude / codex / gemini / anthropic / openai / gemini-api / qwen-api / deepseek / copilot
MODE="idle"            # 接收模式: idle（IMAP IDLE，实时推送）/ poll（定时轮询）
POLL_INTERVAL="60"     # 轮询间隔（秒），仅 MODE=poll 时生效

# ─── 邮箱环境变量（填写你的真实信息）──────────────────────────
MAIL_126_ADDRESS="your@126.com"
MAIL_126_PASSWORD="your-auth-code"
MAIL_126_ALLOWED="your@126.com"

# MAIL_163_ADDRESS="your@163.com"
# MAIL_163_PASSWORD="your-auth-code"
# MAIL_163_ALLOWED="your@163.com"

# MAIL_QQ_ADDRESS="your@qq.com"
# MAIL_QQ_PASSWORD="your-auth-code"
# MAIL_QQ_ALLOWED="your@qq.com"

# Gmail OAuth（推荐）：
#   1. 在 Google Cloud Console 创建项目并启用 Gmail API
#   2. 创建 OAuth 凭据（桌面应用），下载为 credentials_gmail.json 放到本目录
#   3. 首次运行: python3 email_daemon.py --mailbox gmail --auth  （按提示授权）
# MAIL_GMAIL_ADDRESS="your@gmail.com"
# MAIL_GMAIL_ALLOWED="your@gmail.com"
# Gmail 应用专用密码（简单方式）：
# MAIL_GMAIL_ADDRESS="your@gmail.com"
# MAIL_GMAIL_PASSWORD="xxxx xxxx xxxx xxxx"
# MAIL_GMAIL_ALLOWED="your@gmail.com"

# Outlook OAuth：
#   1. 在 Azure Portal 注册应用，获取 Client ID
#   2. 首次运行: python3 email_daemon.py --mailbox outlook --auth  （设备码授权）
# MAIL_OUTLOOK_ADDRESS="your@outlook.com"
# OUTLOOK_CLIENT_ID="your-azure-app-client-id"
# MAIL_OUTLOOK_ALLOWED="your@outlook.com"

# ─── AI API Key（按需填写）──────────────────────────────────────
# ANTHROPIC_API_KEY="sk-ant-xxx"
# OPENAI_API_KEY="sk-xxx"
# GEMINI_API_KEY="AIzaxxx"
# QWEN_API_KEY="sk-xxx"
# DEEPSEEK_API_KEY="sk-xxx"
# GITHUB_COPILOT_TOKEN="ghu_xxx"   # GitHub Copilot token (ghp_ / ghu_ / ghs_)

# ─── Web Search 配置（可选）────────────────────────────────────
# WEB_SEARCH="true"                # 是否启用网络搜索（true / false）
# WEB_SEARCH_ENGINE="duckduckgo"   # 搜索引擎：duckduckgo（免费）/ wikipedia（免费）/ google / bing
# SEARCH_RESULTS_COUNT="5"         # 返回搜索结果数量
# WIKIPEDIA_LANG="zh"              # Wikipedia 语言，默认中文

# Google Custom Search API（如使用 google 引擎）：
# GOOGLE_API_KEY="your-api-key"
# GOOGLE_CSE_ID="your-cse-id"

# Bing Search API（如使用 bing 引擎）：
# BING_API_KEY="your-bing-api-key"

# ─── 外部数据与定时任务（默认方案）────────────────────────────
# WEATHER_API_KEY="your-weatherapi-key"
# NEWS_API_KEY="your-newsapi-key"
# TASK_DEFAULT_AI="openai"             # 定时任务默认使用的 AI（不填则用 --ai 参数）
# WEATHER_DEFAULT_LOCATION="Tokyo"
# NEWS_DEFAULT_QUERY="technology OR AI"
# NEWS_DEFAULT_LANGUAGE="zh"
# NEWS_DEFAULT_COUNTRY=""
# NEWS_DEFAULT_PAGE_SIZE="8"
