# ─── 运行参数 ─────────────────────────────────────────────────
MAILBOX="126"
AI="deepseek"
# MODE="idle"            # idle（IMAP IDLE，默认）/ poll（定时轮询）
# POLL_INTERVAL="60"     # 轮询间隔（秒），仅 MODE=poll 时生效

# ─── Web UI ───────────────────────────────────────────────────
# WEBUI_HOST="0.0.0.0"   # Web UI 监听地址（默认 0.0.0.0）
# WEBUI_PORT="8000"       # Web UI 端口（默认 8000）
# WEBUI_PASSWORD=""       # Web UI 访问密码（留空则不需要登录）
# WEBUI_SECRET=""         # Session 签名密钥（留空则每次启动自动生成）
# WEBUI_LANG="zh"         # Web UI 界面语言：zh（中文）/ ja（日本語）/ ko（한국어）/ en（English）

# ─── 邮箱配置（填写你的真实信息）────────────────────────────
# 126 / 163 / QQ：需要邮箱授权码（非登录密码），在邮箱设置 → POP3/IMAP → 开启服务时获取
MAIL_126_ADDRESS="your@126.com"
MAIL_126_PASSWORD="your-auth-code"
MAIL_126_ALLOWED="your@126.com"

# MAIL_163_ADDRESS="your@163.com"
# MAIL_163_PASSWORD="your-auth-code"
# MAIL_163_ALLOWED="your@163.com"

# MAIL_QQ_ADDRESS="your@qq.com"
# MAIL_QQ_PASSWORD="your-auth-code"
# MAIL_QQ_ALLOWED="your@qq.com"

# ─── Gmail 应用专用密码（简单，无需 OAuth）──────────────────
# 1. Google 账号 → 安全 → 两步验证 → 应用专用密码 → 生成 16 位密码
# 2. Gmail 设置 → 转发和 POP/IMAP → 启用 IMAP
# MAIL_GMAIL_ADDRESS="your@gmail.com"
# MAIL_GMAIL_PASSWORD="xxxx xxxx xxxx xxxx"
# MAIL_GMAIL_ALLOWED="your@gmail.com"
# MAIL_GMAIL_AUTH="password"   # 使用应用密码时必须加此行；不加则默认使用 OAuth

# ─── Gmail OAuth（推荐）────────────────────────────────────
# 1. Google Cloud Console 创建项目，启用 Gmail API
# 2. 下载 OAuth 凭据文件，保存为 credentials_gmail.json 放到本目录
# 3. 首次授权（仅一次）: python3 email_daemon.py --mailbox gmail --auth
# MAIL_GMAIL_ADDRESS="your@gmail.com"
# MAIL_GMAIL_ALLOWED="your@gmail.com"

# ─── Outlook OAuth（设备码）────────────────────────────────
# 1. Azure Portal 注册应用，获取 Client ID（支持个人 Microsoft 账户）
# 2. 首次授权（仅一次）: python3 email_daemon.py --mailbox outlook --auth
# MAIL_OUTLOOK_ADDRESS="your@outlook.com"
# OUTLOOK_CLIENT_ID="your-azure-app-client-id"
# MAIL_OUTLOOK_ALLOWED="your@outlook.com"

# ─── 其他邮箱（自定义 IMAP/SMTP）──────────────────────────
# 适用于任意支持 IMAP/SMTP + 授权码 / 应用密码 的邮箱
# MAIL_CUSTOM_ADDRESS="your@example.com"
# MAIL_CUSTOM_PASSWORD="your-password"
# MAIL_CUSTOM_ALLOWED="your@example.com"
# MAIL_CUSTOM_IMAP_SERVER="imap.example.com"
# MAIL_CUSTOM_IMAP_PORT="993"
# MAIL_CUSTOM_SMTP_SERVER="smtp.example.com"
# MAIL_CUSTOM_SMTP_PORT="465"
# MAIL_CUSTOM_SMTP_SSL="true"

# ─── AI API Key（按需填写一个）──────────────────────────────
# 国际模型
# DEEPSEEK_API_KEY="sk-xxx"
# ANTHROPIC_API_KEY="sk-ant-xxx"
# OPENAI_API_KEY="sk-xxx"
# GEMINI_API_KEY="AIzaxxx"
# GROQ_API_KEY="gsk_xxx"              # Groq 高速推理
# PERPLEXITY_API_KEY="plx_xxx"        # Perplexity 搜索增强
# COHERE_API_KEY="xxx"                # Cohere 企业级

# 中国模型
# QWEN_API_KEY="sk-xxx"               # 通义千问（阿里云）
# MOONSHOT_API_KEY="sk-xxx"           # 月之暗面 Kimi
# GLM_API_KEY="xxx"                   # 智谱 AI（清华系）
# SPARK_API_KEY="xxx:xxx"             # 讯飞星火（APIKey:APISecret）
# ERNIE_API_KEY="xxx:xxx"             # 百度文心一言（APIKey:SecretKey）
# YI_API_KEY="xxx"                    # 零一万物

# CLI 方式（需预先安装对应 CLI 工具）
# GITHUB_COPILOT_TOKEN="ghu_xxx"   # ghp_ / ghu_ / ghs_ 均可

# ─── Web Search（可选，为 AI 回复注入实时搜索结果）──────────
# WEB_SEARCH="true"
# WEB_SEARCH_ENGINE="google"       # google（默认，无需 API Key）/ duckduckgo / brave / wikipedia / bing
# SEARCH_RESULTS_COUNT="5"
# WIKIPEDIA_LANG="zh"
# GOOGLE_API_KEY="your-api-key"    # 使用 google 引擎时需要
# GOOGLE_CSE_ID="your-cse-id"
# BING_API_KEY="your-bing-api-key"   # 使用 bing 引擎时需要
# BRAVE_API_KEY="your-brave-api-key" # 使用 brave 引擎时需要（免费 2000次/月）

# ─── 定时任务与外部数据（可选）─────────────────────────────
# WEATHER_API_KEY="your-weatherapi-key"    # WeatherAPI
# NEWS_API_KEY="your-newsapi-key"          # NewsAPI
# TASK_DEFAULT_AI="deepseek"               # 定时任务使用的 AI（不填则用启动参数 --ai）
# WEATHER_DEFAULT_LOCATION="Tokyo"
# NEWS_DEFAULT_QUERY="technology OR AI"
# NEWS_DEFAULT_LANGUAGE="zh"
# NEWS_DEFAULT_PAGE_SIZE="8"

# ─── MCP（Model Context Protocol）插件（可选）────────────
# 通过 MCP 扩展 AI 能力，直接用 subprocess 调用本地 MCP 服务器，无需额外依赖库
# 留空则 MCP 功能关闭，不影响其他功能
# MCP_SERVERS=filesystem,github           # 启用的服务器（逗号分隔），不填则全部禁用
# MCP_SERVER_FILESYSTEM=npx -y @modelcontextprotocol/server-filesystem /home/user/reports
# MCP_SERVER_GITHUB=npx -y @modelcontextprotocol/server-github
# MCP_SERVER_SQLITE=npx -y @modelcontextprotocol/server-sqlite /path/to/db.sqlite
# 使用示例（邮件指令）：
#   task_type: mcp_call
#   task_payload: {"server": "filesystem", "tool": "list_directory", "args": {"path": "/home/user/reports"}}
#   查询可用工具：{"server": "filesystem", "tool": "__list__"}

# ─── 高级选项（可选）──────────────────────────────────────
# ATTACHMENT_MAX_SIZE_MB="10"     # 附件大小上限（MB），超出则跳过，默认 10MB
# AI_CONCURRENCY="3"              # 同时调用 AI 的最大并发数，默认 3
# CONTEXT_MAX_DEPTH="5"           # 获取会话历史的最大层数，默认 5
# MAX_EMAIL_CHARS="4000"          # 邮件正文最大字符数（超出截断），默认 4000
# PROMPT_LANG="zh"                # 提示语言：zh（中文）/ ja（日本語）/ en（English）（可被邮件语言自动检测覆盖）
# PROMPT_TEMPLATE_FILE=""         # 自定义提示模板文件路径（优先于 PROMPT_LANG）
